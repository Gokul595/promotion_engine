<h1>Your Cart</h1>

<% if @cart && @cart_items.any? %>
  <table class="cart-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Quantity</th>
        <th>Per Unit Price</th>
        <th>Total Price</th>
        <th>Discount</th>
        <th>Price After Discount</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |cart_item| %>
        <tr>
          <td><%= cart_item.item.name %></td>
          <td><%= cart_item.quantity %></td>
          <td><%= number_to_currency(cart_item.item.selling_price) %></td>
          <td><%= number_to_currency(cart_item.total_price) %></td>
          <td>
            <% if cart_item.promotion_id %>
              <%= number_to_currency(cart_item.discount_value) %> - <%= cart_item.promotion.name %>
            <% else %>
              N/A
            <% end %>
          </td>
          <td><%= number_to_currency(cart_item.total_price_after_discount) %></td>
          <td>
            <%= button_to 'Remove', remove_from_cart_item_path(cart_item.item), method: :delete, data: { confirm: 'Are you sure?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="cart-summary">
    <div class="cart-total-before-discount">
      <strong>Total Amount: </strong> <%= number_to_currency(@cart.total_price_before_discount) %>
    </div>
    <div class="cart-total-discount">
      <strong>Total Discount: </strong> <%= number_to_currency(@cart.total_discount) %>
    </div>
    <div class="cart-total">
      <strong>Final Amount: </strong> <%= number_to_currency(@cart.total_price) %>
    </div>
  </div>

  <div class="cart-actions">
    <%= button_to 'Continue Shopping', items_path, method: :get, class: 'button' %>
    <%= button_to 'Checkout', '#', method: :get, class: 'button primary' %>
  </div>
<% else %>
  <p>Your cart is empty.</p>
  <%= button_to 'Start Shopping', items_path, method: :get, class: 'button' %>
<% end %>